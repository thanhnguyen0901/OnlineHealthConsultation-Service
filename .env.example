# =============================================================================
# .env.example — Environment variable template
#
# LOCAL DEVELOPMENT: copy this file to .env and fill in real values.
# RAILWAY DEPLOYMENT: set each variable as a Railway Service Variable.
#   Do NOT commit .env to git.
# =============================================================================

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
NODE_ENV=production
# PORT: Railway automatically injects its own PORT. Only set this locally.
PORT=4000

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Local development:
#   DATABASE_URL="mysql://username:password@localhost:3306/health_consultation_db"
#
# Railway: add a MySQL service to your Railway project, then use a reference
# variable so Railway auto-wires the connection string:
#   DATABASE_URL=${{MySQL.DATABASE_URL}}
#
# The Railway MySQL DATABASE_URL format is:
#   mysql://user:password@host:port/database
# This is the exact format Prisma expects — no changes needed.
DATABASE_URL=mysql://username:password@host:3306/database

# ---------------------------------------------------------------------------
# JWT — must be long, random, and different from each other.
# Generate secure values with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# ---------------------------------------------------------------------------
JWT_SECRET=replace-with-a-64-byte-random-hex-string
JWT_REFRESH_SECRET=replace-with-a-different-64-byte-random-hex-string

JWT_SECRET=8c6f8c5c9a3c4c9a7e5d4e3b2f1a6c9d3e7b8a4f6d2c1e9b5f7a3c8d1e6f9a2b4c7d8e1f3a5b6c9d2e4f7a8b1c3d5e6
JWT_REFRESH_SECRET=5e9a2c7d4b8f1e6c3a9d5b7f2c4e8a1d6f3b9c7e2a5d8f4b1c6e9a3d7f2c5b8e4a1d6c9f3b7e2a5d8c4f1b6e9a3d7
JWT_ACCESS_EXPIRE=30m
JWT_REFRESH_EXPIRE=7d
# Practical values for a deployed app:
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# ---------------------------------------------------------------------------
# CORS
# Set to the deployed frontend URL(s). Comma-separated for multiple origins.
# Example: CORS_ORIGIN=https://my-frontend.vercel.app
# ---------------------------------------------------------------------------
CORS_ORIGIN=https://your-frontend.vercel.app

# ---------------------------------------------------------------------------
# Cookie
#
# COOKIE_SECURE must be true in production.
#   The server will refuse to start if NODE_ENV=production and COOKIE_SECURE=false.
#   Railway serves all apps over HTTPS — always set true in production.
#
# COOKIE_SAMESITE must be "none" when the frontend and backend are on different
#   domains (e.g., Vercel frontend + Railway backend). SameSite=none is required
#   for the browser to send httpOnly cross-origin cookies. Must be used with
#   COOKIE_SECURE=true.
#   Use "lax" only when both apps share the same domain.
# ---------------------------------------------------------------------------
COOKIE_SECURE=true
COOKIE_SAMESITE=none
# COOKIE_DOMAIN=  # Optional: only needed for subdomain cookie sharing (e.g., .yourdomain.com)

# ---------------------------------------------------------------------------
# Application — all have safe built-in defaults. Override only if needed.
# ---------------------------------------------------------------------------
# BCRYPT_ROUNDS: password hashing cost. 12 is the production default.
BCRYPT_ROUNDS=12

# APPOINTMENT_DURATION_MINUTES: slot length for conflict detection.
APPOINTMENT_DURATION_MINUTES=60

# REFRESH_GRACE_WINDOW_MS: window (ms) in which a reused refresh token returns
# 409 TOKEN_ROTATED instead of 401 + full session revocation. Prevents false
# positives on F5-reload / multi-tab races. Set to 0 for strict mode.
REFRESH_GRACE_WINDOW_MS=10000

# ---------------------------------------------------------------------------
# Session Cleanup (cron job — runs daily at 02:00 server time)
# ---------------------------------------------------------------------------
# Days after expiry/revocation before dead session rows are physically deleted.
# Must be >= JWT_REFRESH_EXPIRE to avoid deleting sessions still within grace window.
SESSION_CLEANUP_RETENTION_DAYS=30

# Max rows deleted per cron batch. Caps DELETE statement size to avoid long locks.
SESSION_CLEANUP_BATCH_SIZE=500
