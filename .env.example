# Environment template for OnlineHealthConsultation-Service

NODE_ENV=development
PORT=4000

# PostgreSQL connection string
DATABASE_URL=postgresql://healthuser:password@localhost:5432/health_consultation_db

# JWT secrets (replace in real environments)
JWT_SECRET=replace-with-strong-secret-at-least-16-chars
JWT_REFRESH_SECRET=replace-with-another-strong-secret-at-least-16-chars
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Security/performance knobs
BCRYPT_ROUNDS=10
