# Server Configuration
NODE_ENV=development
PORT=4000

# Database Configuration
DATABASE_URL="mysql://username:password@localhost:3306/health_consultation_db"

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-change-this-in-production
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# CORS Configuration (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# Cookie Configuration
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
# COOKIE_DOMAIN=  # Optional: for subdomain cookie sharing (e.g., .yourdomain.com)

# Application Configuration
BCRYPT_ROUNDS=10

# Session Cleanup
# Days after expiry/revocation before a dead session row is physically deleted.
# Must be >= refresh token lifetime (JWT_REFRESH_EXPIRE) to avoid deleting
# sessions the client might still attempt to use within the grace window.
SESSION_CLEANUP_RETENTION_DAYS=7

# Duration of a single appointment slot in minutes.
# Used to detect overlapping bookings on both doctor and patient sides.
# Must match your actual scheduling slot length (default: 30 min).
APPOINTMENT_DURATION_MINUTES=30
