// Prisma schema — consolidated baseline
// Represents the final database state after all migrations have been applied.
// See prisma/migrations/ for the incremental history.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  PATIENT
  DOCTOR
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum QuestionStatus {
  PENDING
  ANSWERED
  MODERATED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum RatingStatus {
  VISIBLE
  HIDDEN
}

model User {
  /// UUIDv7, app-generated via newId() — always supplied before INSERT, never DB-default.
  id           String    @id @db.Char(36)
  email        String    @unique
  passwordHash String
  firstName    String
  lastName     String
  role         Role
  isActive     Boolean   @default(true)
  /// NULL = active account; non-NULL = deactivated at that timestamp.
  /// Kept in sync with isActive by AdminService (deactivate sets both, reactivate clears both).
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  patientProfile PatientProfile?
  doctorProfile  DoctorProfile?
  sessions       UserSession[]

  // email is covered by its own UNIQUE index — a plain @@index would be redundant.
  @@index([role])
  @@index([deletedAt])
  @@map("users")
}

model PatientProfile {
  /// UUIDv7, app-generated via newId() — always supplied before INSERT, never DB-default.
  id             String    @id @db.Char(36)
  userId         String    @unique @db.Char(36)
  dateOfBirth    DateTime?
  gender         Gender?
  phone          String?
  address        String?
  medicalHistory String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions    Question[]
  appointments Appointment[]
  ratings      Rating[]

  // userId is covered by its own UNIQUE index — a plain @@index would be redundant.
  @@map("patient_profiles")
}

model DoctorProfile {
  /// UUIDv7, app-generated via newId() — always supplied before INSERT, never DB-default.
  id                String    @id @db.Char(36)
  userId            String    @unique @db.Char(36)
  specialtyId       String    @db.Char(36)
  bio               String?   @db.Text
  yearsOfExperience Int       @default(0)
  ratingAverage     Float     @default(0)
  ratingCount       Int       @default(0)
  /// Mirrors User.isActive. Set by AdminService on every activate/deactivate
  /// so queries can filter active doctors on this table alone without joining users.
  isActive          Boolean   @default(true)
  /// Native JSON column (MySQL JSON type). Validated by scheduleArraySchema
  /// (src/utils/schedule.ts) before every write. Structure: ScheduleSlot[].
  schedule          Json?
  /// Timestamp written on every schedule change by DoctorService.
  scheduleUpdatedAt DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialty    Specialty     @relation(fields: [specialtyId], references: [id])
  questions    Question[]
  answers      Answer[]
  appointments Appointment[]
  ratings      Rating[]

  // userId is covered by its own UNIQUE index — a plain @@index would be redundant.
  @@index([specialtyId])
  @@index([isActive])
  @@map("doctor_profiles")
}

model Specialty {
  /// UUIDv7, app-generated via newId() — always supplied before INSERT, never DB-default.
  id          String   @id @db.Char(36)
  nameEn      String   @unique
  nameVi      String
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  doctors DoctorProfile[]

  @@index([isActive])
  @@map("specialties")
}

model Question {
  /// UUIDv7, app-generated via newId() — always supplied before INSERT, never DB-default.
  id               String         @id @db.Char(36)
  patientId        String         @db.Char(36)
  doctorId         String?        @db.Char(36)
  /// Immutable audit field. Written once at creation (= doctorId at that moment).
  /// Never updated afterwards — preserves assignment history even if doctorId is
  /// later SET NULL by a cascade hard-delete of the doctor's User record.
  /// No FK constraint intentionally: the audit value must survive doctor deletion.
  originalDoctorId String?        @db.Char(36)
  title            String
  content          String         @db.Text
  status           QuestionStatus @default(PENDING)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  patient PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  /// SET NULL is intentional: a hard-delete of a DoctorProfile (via User CASCADE)
  /// nullifies doctorId but originalDoctorId permanently records the assignment.
  doctor  DoctorProfile? @relation(fields: [doctorId], references: [id])
  answers Answer[]

  @@index([patientId])
  @@index([doctorId])
  @@index([originalDoctorId])
  @@index([status])
  @@map("questions")
}

model Answer {
  /// UUIDv7, app-generated via newId() — always supplied before INSERT, never DB-default.
  id         String   @id @db.Char(36)
  questionId String   @db.Char(36)
  doctorId   String   @db.Char(36)
  content    String   @db.Text
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  question Question      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  doctor   DoctorProfile @relation(fields: [doctorId], references: [id])

  @@index([questionId])
  @@index([doctorId])
  @@map("answers")
}

model Appointment {
  /// UUIDv7, app-generated via newId() — always supplied before INSERT, never DB-default.
  id              String            @id @db.Char(36)
  patientId       String            @db.Char(36)
  doctorId        String            @db.Char(36)
  scheduledAt     DateTime
  /// Duration of this slot in minutes (DB default: 60).
  /// Stored per-row so overlap detection in createAppointment() uses the actual
  /// duration of each existing booking rather than a global env-var constant.
  durationMinutes Int               @default(60)
  status          AppointmentStatus @default(PENDING)
  reason          String            @db.Text
  notes           String?           @db.Text
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  patient PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  DoctorProfile  @relation(fields: [doctorId], references: [id])
  /// 0..1 — one appointment has at most one rating (enforced by @unique on Rating.appointmentId).
  rating  Rating?

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
  @@index([scheduledAt])
  // Composite index for the overlap conflict query (doctorId + status + scheduledAt)
  @@index([doctorId, status, scheduledAt])
  // Composite index for patient-side conflict check
  @@index([patientId, status, scheduledAt])
  @@map("appointments")
}

model Rating {
  /// UUIDv7, app-generated via newId() — always supplied before INSERT, never DB-default.
  id            String       @id @db.Char(36)
  patientId     String       @db.Char(36)
  doctorId      String       @db.Char(36)
  /// @unique enforces the 0..1 relation with Appointment: at most one Rating per appointment.
  /// @unique enforces the 1:0..1 relation with Appointment.
  /// One rating per appointment maximum — replaces the former UNIQUE(appointmentId, patientId).
  appointmentId String       @unique @db.Char(36)
  /// Integer 1-5. Enforced by CHECK constraint in the DB (chk_ratings_score).
  score         Int
  comment       String?      @db.Text
  status        RatingStatus @default(VISIBLE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  patient     PatientProfile @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor      DoctorProfile  @relation(fields: [doctorId], references: [id])
  appointment Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
  @@map("ratings")
}

model UserSession {
  /// UUIDv7, app-generated via newId() — always supplied before INSERT, never DB-default.
  id               String    @id @db.Char(36)
  userId           String    @db.Char(36)
  /// SHA-256 hash of the refresh token. Unique to prevent duplicate sessions.
  refreshTokenHash String    @unique
  expiresAt        DateTime
  revokedAt        DateTime?
  lastUsedAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())
  userAgent        String?   @db.Text
  ipAddress        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Plain @@index([refreshTokenHash]) is redundant with @unique above.
  // Plain @@index([userId]) is superseded by the composite below.
  /// Composite covers the hot active-session query:
  /// WHERE userId = ? AND revokedAt IS NULL AND expiresAt > NOW()
  /// The leading userId column also satisfies plain userId-only lookups.
  @@index([userId, revokedAt, expiresAt], map: "user_sessions_active_session_idx")
  /// Retained for the session-cleanup job which range-scans on expiresAt alone.
  @@index([expiresAt])
  @@map("user_sessions")
}
